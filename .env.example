# LeadOps Platform - Environment Variables
# Copy this file to .env and fill in your values
# cp .env.example .env

# ====================================================
# xAI / Grok LLM
# ====================================================
XAI_API_KEY=xai-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
XAI_MODEL=grok-beta
XAI_BASE_URL=https://api.x.ai/v1

# ====================================================
# Google Maps API (for lead scraping)
# ====================================================
GOOGLE_MAPS_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ====================================================
# Email / SMTP (for outreach campaigns)
# ====================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=your-email@gmail.com
FROM_NAME=LeadOps Platform

# ====================================================
# Database (PostgreSQL)
# ====================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=leadops
DB_USER=leadops
DB_PASS=changeme_strong_password
DATABASE_URL=postgresql://leadops:changeme@localhost:5432/leadops

# ====================================================
# Redis
# ====================================================
REDIS_URL=redis://localhost:6379/0

# ====================================================
# Service URLs (internal Docker network)
# ====================================================
LEAD_SCRAPER_URL=http://lead-scraper:8001
OUTREACH_URL=http://outreach-engine:8002
CORE_AGENT_URL=http://core-agent:8003

# ====================================================
# Public subdomains (notion.locker)
# ====================================================
API_DOMAIN=https://api.notion.locker
SCRAPER_DOMAIN=https://scraper.notion.locker
OUTREACH_DOMAIN=https://outreach.notion.locker
AGENT_DOMAIN=https://agent.notion.locker
DASHBOARD_DOMAIN=https://dashboard.notion.locker

# ====================================================
# API Security
# ====================================================
LEADOPS_API_KEY=leadops_sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_SECRET=change_this_to_a_long_random_string_at_least_32_chars

# ====================================================
# App settings
# ====================================================
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
MAX_LEADS_PER_RUN=50
DRY_RUN=true
